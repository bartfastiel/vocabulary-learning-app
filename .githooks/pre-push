#!/bin/bash
# Pre-push hook: runs all tests before allowing a push.
# This ensures we never push broken code.

set -e

echo "========================================"
echo "  PRE-PUSH: Running all quality checks"
echo "========================================"

# Step 1: Unit tests
echo ""
echo "--- Step 1/3: Unit Tests (Vitest) ---"
npx vitest run
echo "✓ Unit tests passed"

# Step 2: E2E tests
echo ""
echo "--- Step 2/3: E2E Tests (Playwright) ---"
npx playwright test
echo "✓ E2E tests passed"

# Step 3: Check for common issues
echo ""
echo "--- Step 3/3: Static checks ---"
# Ensure vocab.json is valid JSON
node -e "JSON.parse(require('fs').readFileSync('vocab/vocab.json','utf8')); console.log('✓ vocab.json is valid JSON')"

echo ""
echo "========================================"
echo "  ALL CHECKS PASSED — pushing safely"
echo "========================================"
